# ============================================================================
# Betfair API Credentials
# ============================================================================
# Get these from https://developer.betfair.com/
#
# 1. Create a Betfair account at https://www.betfair.com
# 2. Go to https://developer.betfair.com/ → My Account → Manage App Keys
# 3. Create an Application Key (use "Delayed" for free, "Live" for prod)
# 4. Generate self-signed SSL certificates (see DEPLOYMENT_GUIDE_GCP.md)
#
BETFAIR_USERNAME=your_betfair_username
BETFAIR_PASSWORD=your_betfair_password
BETFAIR_APP_KEY=your_app_key_here
BETFAIR_CERT_PATH=/app/certs/client-2048.crt
BETFAIR_KEY_PATH=/app/certs/client-2048.key

# ============================================================================
# Trading Configuration
# ============================================================================
TRADING_DRY_RUN=true
TRADING_MAX_STAKE=25.0
TRADING_BANKROLL=5000.0

# ============================================================================
# Server Configuration
# ============================================================================
TRADING_SERVER_PORT=8888
API_SERVER_PORT=5000
NEXT_PUBLIC_API_URL=http://localhost:8888
